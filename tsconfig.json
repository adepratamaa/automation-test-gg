{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "node16",
    "lib": ["ES2022", "DOM"],
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node", "@playwright/test"],
    "skipLibCheck": true
  },
  "include": ["playwright.config.ts", "src/**/*.ts", "tests/**/*.ts"],
  "exclude": [
    "node_modules",
    "test-results",
    "playwright-report"
  ]
}
